# EF Core migrations land here.
#
# No migrations exist yet — see issue #12. Once a persistence provider is chosen
# and wired up in PlanDbContextFactory + PersistenceServiceCollectionExtensions,
# generate the initial migration with:
#
#   dotnet ef migrations add InitialCreate \
#     --project src/ERP/Infrastructure/Persistence \
#     --startup-project src/ApiService
#
# Set ERP_PERSISTENCE_CONNECTION first so the design-time factory has a valid
# connection string for the chosen provider.
