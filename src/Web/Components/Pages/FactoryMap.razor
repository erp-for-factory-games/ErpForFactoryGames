@page "/factory/map"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject PlannerApiClient Api
@implements IAsyncDisposable

<PageTitle>Factory map</PageTitle>

<h1>Factory map</h1>

@if (errorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">
        <MudText Typo="Typo.subtitle2"><strong>Map unavailable.</strong></MudText>
        <MudText Typo="Typo.caption">@errorMessage</MudText>
    </MudAlert>
}
else if (loadedSummary is null)
{
    <MudText><em>Loading factory state…</em></MudText>
}

<div class="factory-map-shell">
    <div class="map-legend">
        <MudText Typo="Typo.overline" Class="legend-heading">Layers</MudText>
        @if (layers is { Length: > 0 })
        {
            <div class="layer-list">
                @foreach (var layer in layers)
                {
                    var layerCopy = layer;
                    <div class="layer-toggle">
                        <MudCheckBox T="bool"
                                     Value="layerCopy.Visible"
                                     ValueChanged="@(v => OnLayerToggled(layerCopy.Category, v))"
                                     Color="Color.Primary"
                                     Dense="true"
                                     Size="Size.Small"
                                     Class="layer-checkbox" />
                        <span class="layer-swatch" style="background-color:@layerCopy.Color"></span>
                        <span class="layer-name">@layerCopy.Label</span>
                        <span class="layer-count">@layerCopy.Count</span>
                    </div>
                }
            </div>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Default">No data — ingest a save first.</MudText>
        }
    </div>
    <div id="factory-map-canvas" @ref="mapElement" class="map-canvas"></div>
</div>

@code {
    private ElementReference mapElement;
    private IJSObjectReference? mapModule;
    private LayerInfo[]? layers;
    private string? loadedSummary;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var geojson = await Api.GetFactoryStateGeoJsonAsync();
            if (geojson is null)
            {
                errorMessage = "Couldn't fetch factory state. Ingest a save first?";
                StateHasChanged();
                return;
            }

            mapModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/factory-map.js");
            var rawLayers = await mapModule.InvokeAsync<LayerInfo[]>("initialize", mapElement, geojson);

            layers = rawLayers.Select(l => l with { Visible = true }).ToArray();
            var total = layers.Sum(l => l.Count);
            loadedSummary = $"{total:N0} features across {layers.Length} layers";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            StateHasChanged();
        }
    }

    private async Task OnLayerToggled(string category, bool visible)
    {
        if (mapModule is null) return;
        await mapModule.InvokeVoidAsync("setLayerVisible", category, visible);
        if (layers is null) return;
        for (var i = 0; i < layers.Length; i++)
        {
            if (layers[i].Category == category)
                layers[i] = layers[i] with { Visible = visible };
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (mapModule is not null)
        {
            try
            {
                await mapModule.InvokeVoidAsync("dispose");
                await mapModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit closed */ }
            catch (Exception) { /* best-effort cleanup */ }
        }
    }

    private record LayerInfo(string Category, string Label, string Color, int Count, bool Visible = false);
}
