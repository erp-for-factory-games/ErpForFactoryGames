@page "/planner"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject PlannerApiClient Api
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject PlannerDraftStore DraftStore
@using ERP.Application
@using ERP.Domain
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Planner</PageTitle>

<h1>Production Planner</h1>

<p>Pick what you have on hand (sources) and what you want to produce (sinks). The planner expands recipes backwards and tells you how many buildings of each type you need.</p>

@if (status is { IsLoaded: false })
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
        No catalogue loaded yet. <a href="settings">Point the app at your <code>Docs.json</code> in Settings</a> before planning.
    </MudAlert>
}

@if (items is null)
{
    <MudText><em>Loading catalogue...</em></MudText>
}
else
{
    <MudGrid Spacing="4">
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h5" Class="mb-2">Sources <MudText HtmlTag="span" Typo="Typo.caption" Color="Color.Default">(items/min available)</MudText></MudText>
            @foreach (var row in sources)
            {
                <div class="d-flex gap-2 mb-2 align-items-center">
                    <div class="flex-grow-1">
                        <MudAutocomplete T="CatalogItem"
                                         Value="row.Item"
                                         ValueChanged="@(i => OnRowItemChanged(row, i))"
                                         SearchFunc="@SearchItems"
                                         ToStringFunc="@(i => i?.Name ?? string.Empty)"
                                         Placeholder="Pick item"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Dense="true"
                                         Clearable="true"
                                         CoerceText="true"
                                         CoerceValue="false"
                                         data-row-role="source">
                            <ItemTemplate Context="i">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="/assets/icons/items/@(i.Id).png"
                                         onerror="this.style.visibility='hidden'"
                                         style="width: 24px; height: 24px; object-fit: contain; flex: 0 0 24px;"
                                         alt="" />
                                    <span>@i.Name</span>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </div>
                    <MudNumericField T="decimal" @bind-Value="row.ItemsPerMinute" @bind-Value:after="ScheduleSave"
                                     Min="0" Step="1m"
                                     Placeholder="items / min"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="false"
                                     Style="max-width: 10rem;" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   OnClick="() => RemoveSource(row)"
                                   title="Remove" />
                </div>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="AddSource"
                       StartIcon="@Icons.Material.Filled.Add">
                Add source
            </MudButton>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h5" Class="mb-2">Sinks <MudText HtmlTag="span" Typo="Typo.caption" Color="Color.Default">(items/min wanted)</MudText></MudText>
            @foreach (var row in sinks)
            {
                <div class="d-flex gap-2 mb-2 align-items-center">
                    <div class="flex-grow-1">
                        <MudAutocomplete T="CatalogItem"
                                         Value="row.Item"
                                         ValueChanged="@(i => OnRowItemChanged(row, i))"
                                         SearchFunc="@SearchItems"
                                         ToStringFunc="@(i => i?.Name ?? string.Empty)"
                                         Placeholder="Pick item"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Dense="true"
                                         Clearable="true"
                                         CoerceText="true"
                                         CoerceValue="false"
                                         data-row-role="sink">
                            <ItemTemplate Context="i">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="/assets/icons/items/@(i.Id).png"
                                         onerror="this.style.visibility='hidden'"
                                         style="width: 24px; height: 24px; object-fit: contain; flex: 0 0 24px;"
                                         alt="" />
                                    <span>@i.Name</span>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </div>
                    <MudNumericField T="decimal" @bind-Value="row.ItemsPerMinute" @bind-Value:after="ScheduleSave"
                                     Min="0" Step="1m"
                                     Placeholder="items / min"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="false"
                                     Style="max-width: 10rem;" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   OnClick="() => RemoveSink(row)"
                                   title="Remove" />
                </div>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="AddSink"
                       StartIcon="@Icons.Material.Filled.Add">
                Add sink
            </MudButton>
        </MudItem>
    </MudGrid>

    <div class="mt-4 d-flex flex-wrap align-items-center gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Compute" Disabled="@isComputing">
            @(isComputing ? "Computing..." : "Compute plan")
        </MudButton>

        <MudTextField @bind-Value="planName"
                      Placeholder="Plan name"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Style="max-width: 16rem;" />

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ExportPlan"
                   data-action="export-plan">
            Export JSON
        </MudButton>

        @* Trigger a hidden <InputFile> by id (no MudFileUpload to keep markup light). *@
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Upload"
                   OnClick="TriggerImportPicker"
                   data-action="import-plan">
            Import JSON
        </MudButton>
        <InputFile id="plan-import-input"
                   accept=".json,application/json"
                   OnChange="ImportPlan"
                   style="display:none" />

        @if (hasDraft)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                       OnClick="DiscardDraft"
                       StartIcon="@Icons.Material.Filled.DeleteSweep"
                       data-testid="discard-draft"
                       title="Clear the locally-saved draft and reset the planner to its server-saved state.">
                Discard draft
            </MudButton>
        }
        @if (!string.IsNullOrEmpty(error))
        {
            <MudText HtmlTag="span" Color="Color.Error" Class="ms-3">@error</MudText>
        }
    </div>
}

@if (plan is not null)
{
    <MudDivider Class="my-4" />
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <MudText Typo="Typo.h4" Class="mb-0">Plan</MudText>
        @if (plan.IsFeasible)
        {
            <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.CheckCircle">Feasible</MudChip>
        }
        else
        {
            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Warning">Missing inputs</MudChip>
        }
        @if (plan.Steps.Count > 0)
        {
            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Bolt"
                     title="Sum of base power draw (Building.BasePowerMw x buildings). Variable-power buildings (e.g. miners) report base only.">
                @FormatPower(plan.TotalPowerMw) MW total
            </MudChip>
        }
    </div>

    @if (plan.Steps.Count == 0)
    {
        <MudText><em>No production steps required (everything covered by sources, or no targets given).</em></MudText>
    }
    else
    {
        <MudDataGrid T="StepView"
                     Items="plan.Steps"
                     Hover="true"
                     Striped="true"
                     Dense="true"
                     SortMode="SortMode.Multiple"
                     Class="fx-plan-grid">
            <Columns>
                <PropertyColumn Property="s => s.RecipeName" Title="Recipe" />
                <PropertyColumn Property="s => s.BuildingName" Title="Building" />
                <PropertyColumn Property="s => s.BuildingCount" Title="Buildings" Format="0.##" CellStyle="text-align: right;" HeaderStyle="text-align: right;" />
                <PropertyColumn Property="s => s.PowerMw" Title="Power (MW)" Format="0.##" CellStyle="text-align: right;" HeaderStyle="text-align: right;" />
                <TemplateColumn Title="Inputs / min" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <div class="fx-amount-list">
                            @foreach (var a in context.Item.Inputs)
                            {
                                <span class="fx-amount" title="@a.ItemName">
                                    <img src="/assets/icons/items/@(a.ItemId).png"
                                         onerror="this.style.visibility='hidden'"
                                         alt="" />
                                    <span class="fx-amount-text">@FormatRate(a.ItemsPerMinute) @a.ItemName</span>
                                </span>
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Outputs / min" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <div class="fx-amount-list">
                            @foreach (var a in context.Item.Outputs)
                            {
                                <span class="fx-amount" title="@a.ItemName">
                                    <img src="/assets/icons/items/@(a.ItemId).png"
                                         onerror="this.style.visibility='hidden'"
                                         alt="" />
                                    <span class="fx-amount-text">@FormatRate(a.ItemsPerMinute) @a.ItemName</span>
                                </span>
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }

    @if (plan.RawInputsConsumed.Count > 0)
    {
        <MudText Typo="Typo.h5" Class="mt-4 mb-2">Raw inputs consumed (from sources)</MudText>
        <div class="fx-amount-list">
            @foreach (var amount in plan.RawInputsConsumed)
            {
                <span class="fx-amount" title="@amount.ItemName">
                    <img src="/assets/icons/items/@(amount.ItemId).png"
                         onerror="this.style.visibility='hidden'"
                         alt="" />
                    <span class="fx-amount-text">@FormatRate(amount.ItemsPerMinute) @amount.ItemName / min</span>
                </span>
            }
        </div>
    }

    @if (plan.MissingInputs.Count > 0)
    {
        <MudText Typo="Typo.h5" Color="Color.Error" Class="mt-4 mb-1">Missing inputs</MudText>
        <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block mb-2">No recipe and no source available.</MudText>
        <div class="fx-amount-list">
            @foreach (var amount in plan.MissingInputs)
            {
                <span class="fx-amount fx-amount-missing" title="@amount.ItemName">
                    <img src="/assets/icons/items/@(amount.ItemId).png"
                         onerror="this.style.visibility='hidden'"
                         alt="" />
                    <span class="fx-amount-text">@FormatRate(amount.ItemsPerMinute) @amount.ItemName / min</span>
                </span>
            }
        </div>
    }
}

@code {
    private CatalogItem[]? items;
    private CatalogueStatusView? status;
    private List<Row> sources = [new()];
    private List<Row> sinks = [new()];
    private PlanResponse? plan;
    private string? error;
    private bool isComputing;
    private string planName = string.Empty;
    private Guid planId = Guid.NewGuid();
    private DateTime planCreatedUtc = DateTime.UtcNow;

    // Auto-save (#78). Debounce timer collapses bursts of edits into a
    // single LocalStorage write; we also stage the latest snapshot on every
    // edit so the JS-side beforeunload flush can rescue in-flight changes.
    // Restoration is deferred to OnAfterRenderAsync(firstRender) because
    // IJSRuntime isn't usable from OnInitializedAsync on a server-side
    // component (no JS connection yet).
    private const int DebounceMs = 500;
    private System.Timers.Timer? saveTimer;
    private bool restoreChecked;
    private bool hasDraft;
    private bool suppressSaveScheduling;

    protected override async Task OnInitializedAsync()
    {
        status = await Api.GetCatalogueStatusAsync();
        items = await Api.GetItemsAsync();

        saveTimer = new System.Timers.Timer(DebounceMs) { AutoReset = false };
        saveTimer.Elapsed += async (_, _) => await InvokeAsync(SaveDraftNowAsync);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || restoreChecked) return;
        restoreChecked = true;
        await TryRestoreDraftAsync();
    }

    private async Task TryRestoreDraftAsync()
    {
        try
        {
            var draft = await DraftStore.LoadAsync();
            if (draft is null) return;

            // "differs from any loaded server plan" - Planner doesn't yet
            // load a server plan into the editor (that path lives in #77's
            // work). The current baseline is the empty editor, so any
            // non-empty draft is worth restoring.
            if (IsEmptyDraft(draft)) return;

            suppressSaveScheduling = true;
            try
            {
                ApplyDraft(draft);
            }
            finally
            {
                suppressSaveScheduling = false;
            }

            hasDraft = true;
            Snackbar.Add("Draft restored", Severity.Info);
            StateHasChanged();
        }
        catch (Exception)
        {
            // Don't let a flaky restore break the planner.
        }
    }

    private void ApplyDraft(PlannerDraft draft)
    {
        sources = draft.Sources.Select(RowFromDraft).ToList();
        sinks = draft.Sinks.Select(RowFromDraft).ToList();
        if (sources.Count == 0) sources.Add(new());
        if (sinks.Count == 0) sinks.Add(new());
    }

    private Row RowFromDraft(PlannerDraftRow r)
    {
        var item = r.ItemId is null ? null : items?.FirstOrDefault(i => i.Id == r.ItemId);
        return new Row { Item = item, ItemsPerMinute = r.ItemsPerMinute };
    }

    private PlannerDraft BuildDraft() => new(
        Sources: sources.Select(r => new PlannerDraftRow(r.Item?.Id, r.ItemsPerMinute)).ToList(),
        Sinks: sinks.Select(r => new PlannerDraftRow(r.Item?.Id, r.ItemsPerMinute)).ToList());

    private static bool IsEmptyDraft(PlannerDraft d) =>
        d.Sources.All(IsEmptyRow) && d.Sinks.All(IsEmptyRow);

    private static bool IsEmptyRow(PlannerDraftRow r) =>
        string.IsNullOrEmpty(r.ItemId) && r.ItemsPerMinute == 0;

    /// <summary>
    /// Restart the debounce timer and stage the latest snapshot for the
    /// JS-side beforeunload flush. Cheap enough to call on every change.
    /// </summary>
    private void ScheduleSave()
    {
        if (suppressSaveScheduling) return;
        if (saveTimer is null) return;

        saveTimer.Stop();
        saveTimer.Start();

        // Fire-and-forget the staging interop so we don't block the UI
        // thread; the staged copy only matters if the user closes the tab
        // before the debounce timer fires.
        _ = StagePendingSafeAsync();
    }

    private async Task StagePendingSafeAsync()
    {
        try
        {
            await DraftStore.StagePendingAsync(BuildDraft());
        }
        catch (Exception)
        {
            // JS may be unreachable during prerender / disconnect - ignore.
        }
    }

    private async Task SaveDraftNowAsync()
    {
        try
        {
            var draft = BuildDraft();
            if (IsEmptyDraft(draft))
            {
                // Auto-discard empty drafts so the "Discard draft" button
                // and restore-on-load don't trip over a meaningless record.
                await DraftStore.ClearAsync();
                hasDraft = false;
            }
            else
            {
                await DraftStore.SaveAsync(draft);
                hasDraft = true;
            }
            StateHasChanged();
        }
        catch (Exception)
        {
            // Best-effort - don't surface auto-save failures to the user.
        }
    }

    private void OnRowItemChanged(Row row, CatalogItem? item)
    {
        row.Item = item;
        ScheduleSave();
    }

    private void AddSource()
    {
        sources.Add(new());
        ScheduleSave();
    }

    private void RemoveSource(Row row)
    {
        sources.Remove(row);
        if (sources.Count == 0) sources.Add(new());
        ScheduleSave();
    }

    private void AddSink()
    {
        sinks.Add(new());
        ScheduleSave();
    }

    private void RemoveSink(Row row)
    {
        sinks.Remove(row);
        if (sinks.Count == 0) sinks.Add(new());
        ScheduleSave();
    }

    private async Task DiscardDraft()
    {
        try
        {
            await DraftStore.ClearAsync();
        }
        catch (Exception)
        {
            // Ignore - UI reset below is still useful.
        }
        suppressSaveScheduling = true;
        try
        {
            // "Revert to the server-saved state." Server-side plan loading
            // isn't wired into this page yet (#77), so the server baseline
            // is the empty editor.
            sources = [new()];
            sinks = [new()];
            plan = null;
            error = null;
            hasDraft = false;
        }
        finally
        {
            suppressSaveScheduling = false;
        }
        Snackbar.Add("Draft discarded", Severity.Success);
        StateHasChanged();
    }

    private async Task Compute()
    {
        error = null;
        plan = null;
        isComputing = true;
        try
        {
            var request = new PlanRequest(
                Targets:   sinks  .Where(r => r.Item is not null).Select(r => new TargetInput(r.Item!.Id, r.ItemsPerMinute)).ToList(),
                Available: sources.Where(r => r.Item is not null).Select(r => new AvailabilityInput(r.Item!.Id, r.ItemsPerMinute)).ToList());

            if (request.Targets.Count == 0)
            {
                error = "Add at least one sink.";
                return;
            }

            plan = await Api.ComputePlanAsync(request);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isComputing = false;
        }
    }

    private static string FormatRate(decimal rate) =>
        rate == Math.Floor(rate) ? rate.ToString("0") : rate.ToString("0.##");

    private static string FormatPower(decimal mw) =>
        mw == Math.Floor(mw) ? mw.ToString("0") : mw.ToString("0.##");

    private Task<IEnumerable<CatalogItem>> SearchItems(string? value, CancellationToken ct)
    {
        if (items is null) return Task.FromResult<IEnumerable<CatalogItem>>([]);
        if (string.IsNullOrWhiteSpace(value)) return Task.FromResult<IEnumerable<CatalogItem>>(items);
        var hits = items.Where(i => i.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(hits);
    }

    // -------------------- Export / Import (issue #79) ----------------------
    // Round-trips the current planner state (sources + sinks + name + ids +
    // timestamps) through ERP.Application.PlanSerializer, which writes a
    // versioned JSON envelope. Pure client-state for now — no server endpoint
    // is involved; uploading replaces the in-memory rows.

    private async Task ExportPlan()
    {
        try
        {
            var plan = BuildSavedPlanFromCurrentState();
            var json = PlanSerializer.Serialize(plan);
            var safeName = string.IsNullOrWhiteSpace(plan.Name) ? "plan" : SanitiseFilename(plan.Name);
            await JS.InvokeVoidAsync("erpPlan.downloadJson", $"plan-{safeName}.json", json);
            Snackbar.Add($"Exported {plan.Name}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task TriggerImportPicker()
    {
        await JS.InvokeVoidAsync("document.getElementById('plan-import-input').click");
    }

    private async Task ImportPlan(InputFileChangeEventArgs args)
    {
        try
        {
            var file = args.File;
            if (file is null)
            {
                Snackbar.Add("No file selected.", Severity.Warning);
                return;
            }

            // Plan files are tiny; 1 MB is plenty and keeps memory usage bounded.
            using var stream = file.OpenReadStream(maxAllowedSize: 1_000_000);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var loaded = PlanSerializer.Deserialize(json);
            LoadPlanIntoState(loaded);
            Snackbar.Add($"Imported {loaded.Name}", Severity.Success);
        }
        catch (PlanImportException ex)
        {
            Snackbar.Add($"Couldn't import plan: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't import plan: {ex.Message}", Severity.Error);
        }
    }

    private SavedPlan BuildSavedPlanFromCurrentState()
    {
        var name = string.IsNullOrWhiteSpace(planName) ? "Untitled plan" : planName.Trim();

        var targets = sinks
            .Where(r => r.Item is not null)
            .Select(r => new ProductionTarget(new ItemId(r.Item!.Id), r.ItemsPerMinute))
            .ToList();
        var available = sources
            .Where(r => r.Item is not null)
            .Select(r => new ResourceAvailability(new ItemId(r.Item!.Id), r.ItemsPerMinute))
            .ToList();

        // Use a fresh id only if we don't already have one tracked for this session,
        // so re-export of the same edited plan keeps a stable id.
        if (planId == Guid.Empty) planId = Guid.NewGuid();
        return new SavedPlan(planId, name, targets, available, planCreatedUtc, DateTime.UtcNow);
    }

    private void LoadPlanIntoState(SavedPlan plan)
    {
        // Map ItemIds back to CatalogItem instances so MudAutocomplete renders nicely.
        // Unknown ids (catalogue mismatch) become rows with null Item — the user can
        // see the rate but must repick the item.
        CatalogItem? Find(string id) => items?.FirstOrDefault(i =>
            string.Equals(i.Id, id, StringComparison.Ordinal));

        sources = plan.Available.Count == 0
            ? [new Row()]
            : plan.Available.Select(a => new Row { Item = Find(a.Item.Value), ItemsPerMinute = a.ItemsPerMinute }).ToList();
        sinks = plan.Targets.Count == 0
            ? [new Row()]
            : plan.Targets.Select(t => new Row { Item = Find(t.Item.Value), ItemsPerMinute = t.ItemsPerMinute }).ToList();

        planName = plan.Name;
        planId = plan.Id;
        planCreatedUtc = plan.CreatedUtc;
        // Drop any stale plan result — the user must re-Compute to see numbers
        // that match the freshly loaded inputs.
        this.plan = null;
        error = null;
    }

    private static string SanitiseFilename(string name)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var cleaned = new string(name.Select(c => invalid.Contains(c) ? '_' : c).ToArray()).Trim();
        return string.IsNullOrEmpty(cleaned) ? "plan" : cleaned;
    }

    public async ValueTask DisposeAsync()
    {
        if (saveTimer is not null)
        {
            saveTimer.Stop();
            saveTimer.Dispose();
            saveTimer = null;
        }
        // Final synchronous-ish flush before the circuit goes away. The
        // JS-side beforeunload handler covers tab-close; this covers
        // server-side disposal (e.g. navigating away to another page).
        try
        {
            await SaveDraftNowAsync();
        }
        catch
        {
            // Ignore - connection may already be gone.
        }
    }

    private sealed class Row
    {
        public CatalogItem? Item { get; set; }
        public decimal ItemsPerMinute { get; set; }
    }
}
