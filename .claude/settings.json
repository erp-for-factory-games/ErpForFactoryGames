{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(dotnet restore*)",
      "Bash(dotnet format*)",
      "Bash(dotnet list*)",
      "Bash(dotnet run*)",
      "Bash(dotnet --info)",
      "Bash(dotnet --version)",
      "Bash(npm install*)",
      "Bash(git *)",
      "Bash(gh*)",
      "Bash(curl*)",
      "WebSearch",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:satisfactory.wiki.gg)",
      "WebFetch(domain:satisfactorygame.com)",
      "Skill(update-config)" 
    ]
  },
  "autoMode": {
    "allow": [
      "Editing files under .claude/agents/ in this project is project-managed agent maintenance (e.g. keeping ADA's docs in sync with retired tools), NOT self-modification of Claude's own configuration — allow it.",
      "$defaults"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "pwsh -NoProfile -Command '$input | & (Get-ChildItem $HOME/.claude/plugins/cache/myfoodbag/mfb-statusline/*/statusline-command.ps1 | Select-Object -Last 1)'"
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": false
  },
  "enabledMcpjsonServers": [
    "playwright",
    "aspire"
  ],
  "enableAllProjectMcpServers": true
}