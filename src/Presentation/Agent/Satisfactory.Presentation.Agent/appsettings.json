{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "Agent": {
    "ApiBaseUrl": "",
    "AgentToken": "",
    "SaveFolderPath": null,
    "LogTail": {
      "Enabled": true,
      "Interval": "00:01:00",
      "MaxLinesPerUpload": 500
    }
  }
}
